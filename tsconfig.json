{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noUncheckedIndexedAccess": false,
    "noImplicitOverride": false,
    "exactOptionalPropertyTypes": false,
    "noPropertyAccessFromIndexSignature": false,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/lib/*": ["src/shared/lib/*"],
      "@/services/*": ["src/shared/api/*"],
      "@/types": ["src/shared/types/index.ts"],
      "@/types/*": ["src/shared/types/*"],
      "@app/*": ["src/app/*"],
      "@features/*": ["src/features/*"],
      "@entities/*": ["src/shared/entities/*"],
      "@shared/*": ["src/shared/*"],
      "@config/*": ["src/config/*"],
      "@store/*": ["src/app/store/*"],
      "@utils/*": ["src/shared/utils/*"],
      "@hooks/*": ["src/shared/hooks/*"],
      "@services/*": ["src/shared/api/*"],
      "@components/*": ["src/shared/components/*"],
      "@/components/*": ["src/shared/components/primitives/*"],
      "@/components/ui/*": ["src/shared/components/primitives/ui/*"],
      "@/hooks/*": ["src/shared/hooks/*"],
    }
  },
  "include": ["src"],
  "exclude": ["src/test_zod_schema.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
