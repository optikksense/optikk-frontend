# Ensure package-lock.json is in sync (same check CI runs)
npm ci --dry-run 2>/dev/null
if [ $? -ne 0 ]; then
    echo "[Optikk Frontend] package-lock.json is out of sync with package.json."
    echo "Run 'npm install' and commit the updated lock file."
    exit 1
fi

npx lint-staged

npm run lint
if [ $? -ne 0 ]; then
    echo "[Optikk Frontend] Lint failed. Commit aborted."
    exit 1
fi

npm run type-check
if [ $? -ne 0 ]; then
    echo "[Optikk Frontend] Type check failed. Commit aborted."
    exit 1
fi

npm run test:run
if [ $? -ne 0 ]; then
    echo "[Optikk Frontend] Tests failed. Commit aborted."
    exit 1
fi

npm run build
if [ $? -ne 0 ]; then
    echo "[Optikk Frontend] Build failed. Commit aborted."
    exit 1
fi
