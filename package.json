{
  "name": "observability-frontend-react",
  "version": "1.0.0",
  "type": "module",
  "description": "Optikk Observability Platform - React Frontend",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "ci:budgets": "node scripts/check-budgets.js",
    "ci:marketing-assets": "node scripts/check-marketing-assets.mjs",
    "ci": "yarn type-check && yarn lint && yarn ci:marketing-assets && yarn build && yarn ci:budgets",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:colors": "node scripts/check-no-raw-colors.mjs",
    "format": "biome format --write .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
