    "@types/react-grid-layout": "^1.3.6",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "lucide-react": {
      "react": "$react"
